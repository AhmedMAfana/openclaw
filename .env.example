# ========================================
# TAGH Dev Bootstrap Environment
# ========================================
# Only infrastructure settings go here.
# Provider config (LLM, Telegram, GitHub) is stored in the database.
# Run `python -m openclow.setup` to configure providers.

DATABASE_URL=postgresql+asyncpg://openclow:openclow@postgres:5432/openclow
REDIS_URL=redis://:openclow@redis:6379/0
REDIS_PASSWORD=openclow
POSTGRES_PASSWORD=openclow
LOG_LEVEL=INFO
