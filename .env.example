# ========================================
# TAGH Dev Bootstrap Environment
# ========================================
# Only infrastructure settings go here.
# Provider config (LLM, Telegram, GitHub) is stored in the database.
# Run `python -m taghdev.setup` to configure providers.

DATABASE_URL=postgresql+asyncpg://taghdev:taghdev@postgres:5432/taghdev
REDIS_URL=redis://:taghdev@redis:6379/0
REDIS_PASSWORD=taghdev
POSTGRES_PASSWORD=taghdev
LOG_LEVEL=INFO
# Groq API (speech-to-text, free tier)
GROQ_API_KEY=