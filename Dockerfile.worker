FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl wget ca-certificates gnupg openssh-client jq unzip procps ffmpeg \
    && rm -rf /var/lib/apt/lists/*

# NVM + Node.js — agents can run `nvm install X && nvm use X` to switch versions
ENV NVM_DIR=/usr/local/nvm
ENV NODE_VERSION=20
RUN mkdir -p $NVM_DIR \
    && curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash \
    && . $NVM_DIR/nvm.sh \
    && nvm install $NODE_VERSION \
    && nvm alias default $NODE_VERSION \
    # Symlink active version into /usr/local/bin so non-login shells can use node/npm
    && node_ver=$(ls $NVM_DIR/versions/node/) \
    && ln -sf $NVM_DIR/versions/node/$node_ver/bin/node /usr/local/bin/node \
    && ln -sf $NVM_DIR/versions/node/$node_ver/bin/npm /usr/local/bin/npm \
    && ln -sf $NVM_DIR/versions/node/$node_ver/bin/npx /usr/local/bin/npx \
    # Profile for interactive shells (agent bash sessions: nvm install / nvm use)
    && printf 'export NVM_DIR=%s\n[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"\n' \
       "$NVM_DIR" > /etc/profile.d/nvm.sh && chmod +x /etc/profile.d/nvm.sh

# GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# PHP + Composer (Debian default PHP — works with Laravel 10/11)
RUN apt-get update && apt-get install -y --no-install-recommends \
    php-cli php-mbstring php-xml php-curl \
    php-zip php-mysql php-pgsql php-sqlite3 \
    php-bcmath php-intl php-gd \
    && rm -rf /var/lib/apt/lists/*
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# Docker CLI (to manage project containers)
RUN curl -fsSL https://get.docker.com | sh

# Cloudflare Tunnel (temporary public URLs for project health checks)
RUN curl -fsSL https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-$(dpkg --print-architecture) \
    -o /usr/local/bin/cloudflared && chmod +x /usr/local/bin/cloudflared

# Claude Code CLI + Playwright MCP (both globally installed via npm).
# `@playwright/mcp` ships a `playwright-mcp` shim in the node bin dir;
# we symlink it to /usr/local/bin/playwright-mcp so the Claude Code MCP
# registration can target a stable path that survives Node upgrades
# (the NVM version number in /usr/local/nvm/versions/node/<ver>/bin/
# changes whenever NODE_VERSION is bumped).
RUN npm install -g @anthropic-ai/claude-code@latest @playwright/mcp@latest \
    && ln -sf $(npm prefix -g)/bin/playwright-mcp /usr/local/bin/playwright-mcp

# Playwright browsers — install to shared path so any user can access.
# Baked at image build time so first launch is instant; no lazy download
# on MCP handshake (which Claude Code's short init timeout would fail on).
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN npx playwright install --with-deps chromium

# Python Playwright (for tests)
RUN pip install --no-cache-dir playwright

# Git identity
RUN git config --system user.email "openclow@bot.local" \
    && git config --system user.name "TAGH Dev Bot"

# Python app
WORKDIR /app
COPY pyproject.toml ./
COPY src/ ./src/

RUN pip install --no-cache-dir -e .

# Workspace + user
RUN mkdir -p /workspaces \
    && useradd -m -s /bin/bash openclow \
    && groupadd -f docker \
    && usermod -aG docker openclow \
    && mkdir -p /home/openclow/.claude \
    && chown -R openclow:openclow /app /workspaces /home/openclow $NVM_DIR
# Entrypoint that restores Claude credentials from volume
COPY scripts/worker-entrypoint.sh /usr/local/bin/worker-entrypoint.sh
RUN chmod +x /usr/local/bin/worker-entrypoint.sh

USER openclow

ENTRYPOINT ["worker-entrypoint.sh"]
CMD ["arq", "openclow.worker.arq_app.WorkerSettings"]
